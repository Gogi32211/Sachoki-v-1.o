# ── dashboard service env vars ─────────────────────────────────────────────
# Copy this file to .env.local for local dev (never commit .env.local)

# URL of the scanner-api service (set in Railway dashboard)
SCANNER_API_URL=https://scanner-api.sachoki-prod.railway.app

# URL of the research-api service
RESEARCH_API_URL=https://research-api.sachoki-prod.railway.app

# Shared PostgreSQL (set automatically by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:pass@host:5432/sachoki

# Shared Redis (set automatically by Railway Redis plugin)
REDIS_URL=redis://default:pass@host:6379

# For AI summary features
ANTHROPIC_API_KEY=sk-ant-...

# For all_us universe data
MASSIVE_API_KEY=...

# Railway injects this automatically
PORT=8080
